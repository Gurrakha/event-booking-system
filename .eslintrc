{
  "env": {
    "node": true,
    "jest": true,
  },
  "extends": [
    "airbnb-base",
    "plugin:@typescript-eslint/recommended",
    "plugin:jest/recommended",
    "plugin:prettier/recommended",
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.json",
  },
  "settings": {
    "import/resolver": {
      "typescript": {
        "project": "./tsconfig.json",
      },
    },
  },
  "rules": {
    "no-console": "warn",
    "quotes": "off",
    "prettier/prettier": [
      "error",
      {
        "singleQuote": true,
        "trailingComma": "all",
        "semi": true,
      },
    ],
    "func-names": "off",
    "no-useless-return": "off",
    "no-underscore-dangle": "off",
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "js": "always",
        "ts": "never",
      },
    ],
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
      },
    ],
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": true,
      },
    ],
  },
}
