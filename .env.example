DATABASE_URL="mysql://root:password@mysql:3306/event_db"
DATABASE_USER="root"
DATABASE_PASSWORD="password"
DATABASE_NAME="event_db"
# If you are running via docker-compose then host will be mysql.
# If you are running backend and mysql separately then please update the host and database_url accordingly
DATABASE_HOST="mysql" 
DATABASE_PORT=3306
PORT=5000
NODE_ENV=development